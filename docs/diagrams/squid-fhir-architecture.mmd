
    flowchart LR
    %% People
    developer["Developer / AI Engineer<br/>Uses Grok Build + Squid to implement and evolve the system"]
    human_reviewer["Human Reviewer<br/>Reviews escalations and makes override decisions"]

    %% External Systems
    fhir_servers["FHIR Servers<br/>HAPI, Firely, mock.health, etc."]
    langfuse["Langfuse<br/>Optional observability and tracing"]

    %% Main System Boundary
    subgraph fhir_validator["FHIR Query Validator Factory"]
        squid["Squid Software Factory<br/>Grok Build + Multi-Agent Pipeline<br/>PA → SWE → Tester → PR Reviewer → On-Call with human gates"]
        workflow["Workflow Orchestrator<br/>Google ADK 2.0 or Python-native<br/>Coordinates specialist agents and feedback loops"]

        subgraph agents["Specialist Agents"]
            cache["CacheAgent<br/>Python + httpx<br/>Fetches and caches CapabilityStatement with ETag / 304 support"]
            validator["QueryValidatorAgent<br/>Python + Pydantic<br/>Validates queries against CapabilityStatement and detects invalid patterns"]
            executor["QueryExecutionAgent<br/>Python + httpx<br/>Executes validated queries and structures results"]
            rule["RuleAndSearchLearnerAgents<br/>Python<br/>Detects patterns, suggests learned rules, and decides escalation"]
            human_gate["HumanInterventionGate<br/>Python<br/>Supports pause / resume, context packaging, and human decision recording"]
        end
    end

    %% Relationships
    developer -->|"Runs /squid-plan and /squid-implement-*"| squid
    squid -->|"Generates and maintains"| workflow

    workflow -->|"Always triggers first"| cache
    workflow -->|"Runs core validation"| validator
    workflow -->|"Executes only when operation is validate_and_execute and query is valid"| executor
    workflow -->|"Invokes on validation failure patterns"| rule
    rule -->|"Escalates when thresholds are exceeded"| human_gate

    human_gate -->|"Presents context and awaits decision"| human_reviewer
    human_reviewer -->|"Resumes or overrides flow"| workflow

    cache -->|"Fetches CapabilityStatement"| fhir_servers
    executor -->|"Executes search queries"| fhir_servers
    workflow -.->|"Sends traces<br/>optional"| langfuse