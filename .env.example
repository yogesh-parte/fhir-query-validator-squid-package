# =============================================================================
# FHIR Query Validator Factory - Environment Configuration Example
# =============================================================================
# Copy this file to .env.local and update the values as needed.
# .env.local is git-ignored — never commit real API keys or tokens.
#
#   cp .env.example .env.local

# -----------------------------------------------------------------------------
# Default Server Configuration
# -----------------------------------------------------------------------------
FHIR_DEFAULT_SERVER_KEY=hapi
FHIR_SERVER_BASE=https://hapi.fhir.org/baseR4

# -----------------------------------------------------------------------------
# Global Authentication (generic protected servers)
# -----------------------------------------------------------------------------
FHIR_USE_AUTH=false
# FHIR_AUTH_TYPE=bearer
# FHIR_AUTH_TOKEN=your-bearer-token-here

# OAuth2 client credentials (when FHIR_AUTH_TYPE=oauth2)
# OAUTH_CLIENT_ID=your-client-id
# OAUTH_CLIENT_SECRET=your-client-secret
# OAUTH_TOKEN_URL=https://your-auth-server.com/oauth2/token
# OAUTH_SCOPE=fhir.read

# -----------------------------------------------------------------------------
# mock.health — authenticated FHIR sandbox (https://mock.health/docs)
# -----------------------------------------------------------------------------
# MOCK_HEALTH_API_KEY=sk_live_your_key_here
# Use at runtime: server_key="mockhealth"

# -----------------------------------------------------------------------------
# Security hardening (production / networked deployments)
# -----------------------------------------------------------------------------
# FHIR_WORKFLOW_ISOLATE_STATE=true
# FHIR_TRUST_CLIENT_USER_ID=false
# FHIR_HUMAN_GATE_REQUIRE_AUTH=true
# FHIR_HUMAN_GATE_OPERATOR_TOKEN=change-me-in-production
# FHIR_VERBOSE_LOGGING=false